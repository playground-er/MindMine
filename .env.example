# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# Supabase project URL — Settings > API > Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase anon/public key — Settings > API > Project API keys > anon public
# This key is safe to expose in the browser. RLS is what protects your data.
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# NEVER put the service_role key here or anywhere in this repo.
# It bypasses RLS entirely.
