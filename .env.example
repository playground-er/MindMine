# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# Supabase project URL — Settings > API > Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase publishable key — Settings > API Keys > publishable
# This key is safe to expose in the browser. RLS is what protects your data.
# New projects issue `sb_publishable_...`; older ones a `eyJhbGci...` JWT.
# Both work here.
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# NEVER put the secret key here or anywhere in this repo — `sb_secret_...`
# (older projects: `service_role`). It bypasses RLS entirely.
# If one ever lands in this file or in chat, rotate it in the dashboard.
